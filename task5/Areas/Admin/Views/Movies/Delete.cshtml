@model Movie
@{
    ViewData["Title"] = "Delete Movie";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Delete Movie</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card shadow-sm border-danger">
    <div class="card-body">
        <div class="alert alert-danger">
            Are you sure you want to delete this movie? This action cannot be undone.
        </div>

        <div class="d-flex gap-3 align-items-start">
            @if (!string.IsNullOrEmpty(Model.PosterPath))
            {
                <img src="@Model.PosterPath" style="height:150px;object-fit:cover;" class="rounded" />
            }
            <div>
                <h4>@Model.Title</h4>
                <p class="text-muted">@Model.DurationMinutes mins</p>
                <p>@Model.Description</p>
            </div>
        </div>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-3">
            <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>