@model CinemaBooking.Models.Hall
@{ ViewData["Title"] = "Delete Hall"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Delete Hall</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card shadow-sm border-danger" style="max-width:400px">
    <div class="card-body">
        <div class="alert alert-danger">
            Delete hall "<strong>@Model.Name</strong>" from <strong>@Model.Cinema?.Name</strong>?
        </div>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>