@model List<CinemaBooking.Models.Booking>
@{
    ViewData["Title"] = "All Bookings";
}

<h2 class="mb-4">All Bookings</h2>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>User</th>
                <th>Movie</th>
                <th>Cinema / Hall</th>
                <th>Showtime</th>
                <th>Seats</th>
                <th>Total</th>
                <th>Status</th>
                <th>Booked At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.User.FullName<br /><small class="text-muted">@b.User.Email</small></td>
                    <td>@b.Showtime.Movie.Title</td>
                    <td>@b.Showtime.Hall.Cinema.Name - @b.Showtime.Hall.Name</td>
                    <td>@b.Showtime.StartTime.ToString("dd MMM yyyy - hh:mm tt")</td>
                    <td>@b.SeatsCount</td>
                    <td>@b.TotalPrice.ToString("C")</td>
                    <td>
                        @if (b.Status == CinemaBooking.Models.BookingStatus.Confirmed)
                        {
                            <span class="badge bg-success">Confirmed</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Cancelled</span>
                        }
                    </td>
                    <td>@b.BookingDate.ToString("dd MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>