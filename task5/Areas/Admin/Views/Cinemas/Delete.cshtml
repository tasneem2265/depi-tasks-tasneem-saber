@model CinemaBooking.Models.Cinema
@{ ViewData["Title"] = "Delete Cinema"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Delete Cinema</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card shadow-sm border-danger" style="max-width:500px">
    <div class="card-body">
        <div class="alert alert-danger">
            Are you sure you want to delete "<strong>@Model.Name</strong>"?
            <br /><small>This will also delete all its halls.</small>
        </div>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>