@model CinemaBooking.Models.Showtime
@{ ViewData["Title"] = "Delete Showtime"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Delete Showtime</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card shadow-sm border-danger" style="max-width:500px">
    <div class="card-body">
        <div class="alert alert-danger">
            Are you sure you want to delete this showtime?
        </div>
        <ul class="list-unstyled mb-3">
            <li><strong>Movie:</strong> @Model.Movie.Title</li>
            <li><strong>Cinema:</strong> @Model.Hall.Cinema.Name</li>
            <li><strong>Hall:</strong> @Model.Hall.Name</li>
            <li><strong>Time:</strong> @Model.StartTime.ToString("dd MMM yyyy - hh:mm tt")</li>
            <li><strong>Price:</strong> @Model.TicketPrice.ToString("C")</li>
        </ul>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>