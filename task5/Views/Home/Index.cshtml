@model List<CinemaBooking.Models.Movie>
@{
    ViewData["Title"] = "Now Showing";
}

<div class="text-center mb-4">
    <h1 class="display-5">Now Showing</h1>
    <p class="text-muted">Browse movies currently playing in our cinemas.</p>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4">
    @if (!Model.Any())
    {
        <p class="text-center">No movies currently showing.</p>
    }
    @foreach (var movie in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img src="@(string.IsNullOrEmpty(movie.PosterPath) ? "/images/no-poster.png" : movie.PosterPath)"
                     class="card-img-top" style="height:300px;object-fit:cover;" alt="@movie.Title poster" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@movie.Title</h5>
                    <p class="card-text text-muted small">
                        @string.Join(", ", movie.MovieCategories.Select(mc => mc.Category.Name))
                    </p>
                    <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id"
                       class="btn btn-primary mt-auto">View Showtimes</a>
                </div>
            </div>
        </div>
    }
</div>

<div class="text-center mt-4">
    <a asp-controller="Movies" asp-action="Index" class="btn btn-outline-secondary">Browse All Movies</a>
</div>