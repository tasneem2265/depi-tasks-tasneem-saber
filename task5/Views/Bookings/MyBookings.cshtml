@model List<CinemaBooking.Models.Booking>
@{
    ViewData["Title"] = "My Bookings";
}

<h1 class="mb-4">My Bookings</h1>

@if (!Model.Any())
{
    <p class="text-muted">You have no bookings yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Movie</th>
                    <th>Cinema / Hall</th>
                    <th>Showtime</th>
                    <th>Seats</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>@b.Showtime.Movie.Title</td>
                        <td>@b.Showtime.Hall.Cinema.Name - @b.Showtime.Hall.Name</td>
                        <td>@b.Showtime.StartTime.ToString("dd MMM yyyy - hh:mm tt")</td>
                        <td>@b.SeatsCount</td>
                        <td>@b.TotalPrice.ToString("C")</td>
                        <td>
                            @if (b.Status == CinemaBooking.Models.BookingStatus.Confirmed)
                            {
                                <span class="badge bg-success">Confirmed</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Cancelled</span>
                            }
                        </td>
                        <td>
                            @if (b.Status == CinemaBooking.Models.BookingStatus.Confirmed && b.Showtime.StartTime > DateTime.UtcNow)
                            {
                                <form asp-action="Cancel" asp-route-id="@b.Id" method="post"
                                      onsubmit="return confirm('Cancel this booking?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}