@model CinemaBooking.Models.ViewModels.BookingCreateViewModel
@{
    ViewData["Title"] = "Book Tickets";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title">@Model.MovieTitle</h3>
                <p class="text-muted mb-1">@Model.CinemaName - @Model.HallName</p>
                <p class="text-muted">@Model.StartTime.ToString("dd MMM yyyy - hh:mm tt")</p>

                <hr />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="ShowtimeId" />
                    <input type="hidden" asp-for="MovieTitle" />
                    <input type="hidden" asp-for="CinemaName" />
                    <input type="hidden" asp-for="HallName" />
                    <input type="hidden" asp-for="StartTime" />
                    <input type="hidden" id="ticketPrice" value="@Model.TicketPrice" />

                    <div class="mb-3">
                        <label class="form-label">Ticket Price</label>
                        <p class="form-control-plaintext">@Model.TicketPrice.ToString("C")</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Seats Available</label>
                        <p class="form-control-plaintext">@Model.SeatsAvailable</p>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SeatsCount" class="form-label"></label>
                        <input asp-for="SeatsCount" id="seatsCount" type="number" min="1" max="@Model.SeatsAvailable"
                               class="form-control" />
                        <span asp-validation-for="SeatsCount" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Total Price</label>
                        <p class="form-control-plaintext fs-4 text-primary" id="totalPrice">
                            @Model.TicketPrice.ToString("C")
                        </p>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Confirm Booking</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const ticketPrice = parseFloat(document.getElementById('ticketPrice').value);
        const seatsInput = document.getElementById('seatsCount');
        const totalPriceEl = document.getElementById('totalPrice');

        function updateTotal() {
            const seats = parseInt(seatsInput.value) || 0;
            const total = (seats * ticketPrice).toFixed(2);
            totalPriceEl.textContent = '$' + total;
        }

        seatsInput.addEventListener('input', updateTotal);
        updateTotal();
    </script>
}