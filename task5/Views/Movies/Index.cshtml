@model List<CinemaBooking.Models.Movie>
@{
    ViewData["Title"] = "Movies";
    var categories = ViewBag.Categories as List<CinemaBooking.Models.Category>;
}

<h1 class="mb-3">All Movies</h1>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-6">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by title..." />
    </div>
    <div class="col-md-4">
        <select name="categoryId" class="form-select" asp-items="@(new SelectList(categories, "Id", "Name", ViewBag.SelectedCategory))">
            <option value="">-- All Categories --</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
</form>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    @if (!Model.Any())
    {
        <p class="text-center">No movies found.</p>
    }
    @foreach (var movie in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img src="@(string.IsNullOrEmpty(movie.PosterPath) ? "/images/no-poster.png" : movie.PosterPath)"
                     class="card-img-top" style="height:280px;object-fit:cover;" alt="@movie.Title poster" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@movie.Title</h5>
                    <p class="card-text small text-muted">@movie.DurationMinutes mins</p>
                    <p class="card-text small">
                        @string.Join(", ", movie.MovieCategories.Select(mc => mc.Category.Name))
                    </p>
                    <a asp-action="Details" asp-route-id="@movie.Id" class="btn btn-primary mt-auto">Details</a>
                </div>
            </div>
        </div>
    }
</div>